generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. AUTH.JS REQUIRED TABLES
// ------------------------------------------------------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // HealthLedger profile fields
  gender        String?   // "male" | "female" | "other"
  dateOfBirth   DateTime?

  // HealthLedger specific relations
  documents      Document[]
  extractedData  ExtractedData[]
  manualTrackers  ManualTracker[]
  medications     Medication[]
  readings        ManualReading[]
  medicationLogs  MedicationLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------
// 2. HEALTHLEDGER CORE TABLES
// ------------------------------------------------------

model Document {
  id           String   @id @default(cuid())
  userId       String
  fileName     String
  fileUrl      String   // URL from UploadThing
  reportDate   DateTime @default(now())
  reportType   String?  // e.g., "CBC", "Lipid Panel", "Thyroid Panel"
  status       String   @default("processed")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  extractedData ExtractedData[]
}

model ExtractedData {
  id                 String   @id @default(cuid())
  userId             String
  documentId         String
  
  // The actual biomarker data
  markerName         String   // e.g., "Fasting Glucose"
  numericValue       Float?   // Stored as a number for trend graphs
  textValue          String?  // Fallback for non-numeric results (e.g., "Positive")
  unit               String?  // e.g., "mg/dL"
  flag               String?  // e.g., "normal", "high", "low"
  
  testDate           DateTime // Inherited from the document for easy querying
  createdAt          DateTime @default(now())

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document           Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  // Index for faster querying when building trend graphs
  @@index([userId, markerName])
}

// ------------------------------------------------------
// 3. MANUAL HEALTH TRACKING
// ------------------------------------------------------

model ManualTracker {
  id        String   @id @default(cuid())
  userId    String
  paramType String   // "blood_pressure" | "blood_sugar" | "weight" | "heart_rate" | "spo2" | "temperature" | "hba1c"
  unit      String   // e.g. "mmHg", "mg/dL", "kg", "bpm", "%", "°C"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  readings ManualReading[]

  @@unique([userId, paramType])
  @@index([userId])
}

model ManualReading {
  id         String        @id @default(cuid())
  userId     String
  trackerId  String
  value      String        // e.g. "120/80" for BP, "95.4" for temp
  recordedAt DateTime      @default(now())
  notes      String?
  createdAt  DateTime      @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracker ManualTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt(sort: Desc)])
  @@index([trackerId])
}

model Medication {
  id        String    @id @default(cuid())
  userId    String
  name      String    // e.g. "Metformin"
  dosage    String    // e.g. "500mg"
  frequency String    // "once_daily" | "twice_daily" | "thrice_daily" | "four_times_daily" | "as_needed" | "weekly"
  notes     String?
  isActive  Boolean   @default(true)
  startDate DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs MedicationLog[]

  @@index([userId])
}

model MedicationLog {
  id           String     @id @default(cuid())
  userId       String
  medicationId String
  takenAt      DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt])
  @@index([medicationId])
}